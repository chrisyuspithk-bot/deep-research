# LLM endpoint (any OpenAI-compatible API)
# Nemotron Super 3 Nano example via vLLM:
LLM_BASE_URL=http://localhost:8080/v1
LLM_API_KEY=not-needed
LLM_MODEL=nvidia/nemotron-super-3-nano

# Model name exposed to OpenWebUI
SERVER_MODEL_NAME=deep-research

# Research depth
N_INITIAL_QUERIES=5
N_FOLLOW_UP_QUERIES=3

# Server
PORT=8000
MAX_CONCURRENT_REQUESTS=3
LOG_LEVEL=INFO
